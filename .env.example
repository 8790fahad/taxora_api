NODE_ENV=development
PORT=4000
DATABASE_URL=mysql://taxora:taxora@localhost:3306/taxora
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
# AES-256 key for encrypting ERP OAuth tokens at rest (use 32+ random chars in prod)
TOKEN_ENCRYPTION_KEY=
CORS_ORIGIN=http://localhost:5173
REMITA_MOCK=true
REMITA_BASE_URL=https://api.remita.net
# Remita payment (subscription billing). Required when REMITA_MOCK=false
REMITA_MERCHANT_ID=
REMITA_SERVICE_TYPE_ID=
REMITA_API_KEY=
REMITA_PUBLIC_KEY=
REMITA_INLINE_SCRIPT=https://login.remita.net/payment/v1/remita-pay-inline.bundle.js
RUN_WORKER=true
API_PUBLIC_URL=http://localhost:4000

# Pay-as-you-go billing
PER_INVOICE_RATE_NGN=10
PER_INVOICE_MIN_FUNDING_NGN=50000

# NRS / FIRS e-invoicing identifiers (MBS payload)
NRS_AGGREGATOR_ID=
NRS_MERCHANT_ID=
NRS_SERVICE_ID=
NRS_INVOICE_TYPE_CODE=396

# Zoho Books OAuth. ZOHO_MOCK=true skips real OAuth for local dev
ZOHO_MOCK=true
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Starting data center only. Each tenant's actual region is auto-detected from
# Zoho's OAuth callback (accounts-server/location), so this supports all regions.
ZOHO_REGION=com
ZOHO_REDIRECT_URI=http://localhost:4000/api/v1/connections/zoho/callback

# Odoo (JSON-RPC). ODOO_MOCK=true returns sample data without a live instance.
# Credentials (base URL, database, username, API key) are entered per-connection.
ODOO_MOCK=true
# TallyPrime (HTTP/XML). TALLY_MOCK=true returns sample data without a running
# Tally instance. Connection is by URL only (no credentials).
TALLY_MOCK=true
# Sage (Intacct) OAuth 2.0. SAGE_MOCK=true returns sample data without real OAuth.
SAGE_MOCK=true
SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=
SAGE_AUTH_URL=https://api.intacct.com/ia/api/v1/oauth2/authorize
SAGE_TOKEN_URL=https://api.intacct.com/ia/api/v1/oauth2/token
SAGE_API_BASE=https://api.intacct.com/ia/api/v1
SAGE_SCOPE=openid offline_access
SAGE_REDIRECT_URI=http://localhost:4000/api/v1/connections/sage/callback
# FlowBooks OAuth 2.0. FLOWBOOKS_MOCK=true returns sample data without real OAuth.
FLOWBOOKS_MOCK=true
FLOWBOOKS_CLIENT_ID=
FLOWBOOKS_CLIENT_SECRET=
FLOWBOOKS_AUTH_URL=https://app.flowbooks.ng/oauth/authorize
FLOWBOOKS_TOKEN_URL=https://app.flowbooks.ng/oauth/token
FLOWBOOKS_API_BASE=https://api.flowbooks.ng/v1
FLOWBOOKS_SCOPE=invoices.read customers.read offline_access
FLOWBOOKS_REDIRECT_URI=http://localhost:4000/api/v1/connections/flowbooks/callback
# Automatic ERP sync interval in hours (BullMQ repeatable job). 0 disables it.
ERP_AUTO_SYNC_HOURS=1

# QuickBooks Online OAuth (Intuit). QB_MOCK=true skips real OAuth for local dev
QB_MOCK=true
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=sandbox
QB_REDIRECT_URI=http://localhost:4000/api/v1/connections/quickbooks/callback
KIRS_CAC_URL=https://etax.kirs.gov.ng/check-cac
KIRS_CSRF_TOKEN=your-kirs-csrf-token
FRONTEND_URL=http://localhost:5173
EMAIL_MOCK=false
VERIFICATION_TTL_HOURS=24
# Secret for admin endpoints (approve manual signup profiles). Leave empty to disable.
ADMIN_API_KEY=

# Mailtrap (https://mailtrap.io)
MAILTRAP_TOKEN=your-mailtrap-api-token
MAIL_FROM="Taxora" <no-reply@inventria.app>

# Email branding
COMPANY_NAME=Taxora
COMPANY_LOGO_URL=https://res.cloudinary.com/your-cloud/image/upload/taxora-icon-192.svg
COMPANY_WEBSITE=http://localhost:5173
COMPANY_EMAIL=hello@taxora.app
COMPANY_PHONE=+2348067643479
COMPANY_TWITTER=https://x.com/flowbooksng
COMPANY_INSTAGRAM=https://www.instagram.com/flowbooksng
COMPANY_LINKEDIN=https://www.linkedin.com/company/flowbooksng
COMPANY_FACEBOOK=https://www.facebook.com/flowbooksng
BRAND_COLOR=#0f766e
